.DS_Store
__pycache__/
.pytest_cache/
*.pyc
.env
.venv/
data/interim/
data/processed/
data/station_daily.csv
outputs/reports/*
outputs/figures/*
outputs/forecasts/*
outputs/diagnostics/tmp/*
forecasts/system_level/*
diagnosis/**/outputs/**
!outputs/reports/.gitkeep
!outputs/figures/.gitkeep
!outputs/forecasts/.gitkeep
!outputs/diagnostics/.gitkeep
!outputs/diagnostics/tmp/.gitkeep
!forecasts/system_level/.gitkeep
!forecasts/system_level/**/.gitkeep
!diagnosis/**/outputs/**/.gitkeep
notebooks/.ipynb_checkpoints/

# Keep large working datasets local by default.
data/raw/**/*.csv
data/raw/**/*.json
data/raw/**/*.Json
data/reference/**/*.csv
data/reference/**/*.json
data/reference/**/*.Json
!data/**/.gitkeep
